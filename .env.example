# Copie este arquivo para .env e preencha os valores.
# No Railway, defina estas mesmas chaves em Variables (não suba o .env para o repo).

# Obrigatório: chave da API do Groq — LLM (https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# Obrigatório p/ o RAG: chave da API da Jina — embeddings (https://jina.ai/embeddings)
# Free tier, sem cartão de crédito.
JINA_API_KEY=your_jina_api_key_here

# Obrigatório em produção: chave de administração (criar/listar/excluir agentes).
# Padrão em dev: admin-dev-key
ADMIN_API_KEY=change-me

# Opcional: modelo do Groq (padrão: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Opcional: modelo de embeddings da Jina (padrão: jina-embeddings-v3)
# JINA_MODEL=jina-embeddings-v3

# Opcional: quantas mensagens do histórico vão ao Groq (padrão: 5)
# HISTORY_LIMIT=5

# Opcional: chunks RAG injetados por pergunta (padrão: 3; menos = menos tokens)
# RAG_TOP_K=3

# Opcional: cria o agente "demo" no primeiro boot (padrão: 1; use 0 p/ desligar)
# SEED_DEMO=1

# Opcional: diretório dos bancos SQLite (core.db, rag.db).
# No Railway, aponte para o mount path do Volume para persistir (ex.: /app/data).
# DB_DIR=/app/data
