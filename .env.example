# Copie este arquivo para .env e preencha os valores.
# No Railway, defina estas mesmas chaves em Variables (não suba o .env para o repo).

# Obrigatório: chave da API do Groq (https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# Opcional: modelo do Groq (padrão: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Opcional: diretório dos bancos SQLite (products.db, rag.db).
# No Railway, aponte para o mount path do Volume para persistir os dados (ex.: /app/data).
# Se vazio, os bancos ficam ao lado do código (efêmero em deploy).
# DB_DIR=/app/data
